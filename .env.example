# Generated by: npm run setup
# Copy these values to Render.com environment variables

NODE_ENV=production
PORT=3000

# Auto-generated secrets (run npm run setup)
JWT_SECRET=replace_with_generated_secret
STEP_TOKEN_SECRET=replace_with_generated_secret
COOKIE_SECRET=replace_with_generated_secret

# The hidden URL path only your group knows
# Example: /sv/g8te  or  /vault/open  or  /k9m2-enter
REAL_AUTH_PATH=/sv/g8te

# Group passphrase (bcrypt hash) - generated by setup script
GROUP_PASSPHRASE_HASH=replace_with_bcrypt_hash

# User 1 (Admin)
USER_1_USERNAME=replace_with_username
USER_1_PASSWORD_HASH=replace_with_bcrypt_hash
USER_1_TOTP_SECRET=replace_with_base32_secret

# User 2
USER_2_USERNAME=replace_with_username
USER_2_PASSWORD_HASH=replace_with_bcrypt_hash
USER_2_TOTP_SECRET=replace_with_base32_secret

# User 3 (optional)
USER_3_USERNAME=
USER_3_PASSWORD_HASH=
USER_3_TOTP_SECRET=

# User 4 (optional)
USER_4_USERNAME=
USER_4_PASSWORD_HASH=
USER_4_TOTP_SECRET=
